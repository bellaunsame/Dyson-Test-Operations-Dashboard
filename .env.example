# Flask configuration
FLASK_SECRET_KEY=supersecret-ops-key-12345

# Mail configuration (Optional - fallback to simulation mode if not set)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_RECIPIENT=recipient@example.com

# SharePoint configuration (Optional - fallback to simulation mode if not set)
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/YourSite
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_DOC_LIB=Shared Documents
